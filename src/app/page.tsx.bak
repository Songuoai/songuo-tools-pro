];

export default function HomePage() {
  const [tools, setTools] = useState<Tool[]>([]);
  const [categories, setCategories] = useState<Category[]>([]);
  const [popularTools, setPopularTools] = useState<Tool[]>([]);
  const [latestTools, setLatestTools] = useState<Tool[]>([]);
  const [loading, setLoading] = useState(true);
  const [visitorCount, setVisitorCount] = useState(1);

  useEffect(() => {
    loadData();
    setVisitorCount(Math.floor(Math.random() * 50) + 1);
    
    const interval = setInterval(() => {
      setVisitorCount(prev => Math.max(1, prev + (Math.floor(Math.random() * 5) - 2)));
    }, 10000);

    return () => clearInterval(interval);
  }, []);

  useEffect(() => {
    const handleFocus = () => {
      loadData();
    };
    window.addEventListener('focus', handleFocus);
    return () => window.removeEventListener('focus', handleFocus);
  }, []);

  async function loadData() {
    try {
      setLoading(true);
      
      const res = await fetch('/api/tools', { 
        cache: 'no-store',
        next: { revalidate: 300 }
      });
      
      if (!res.ok) {
        console.error('API 鍝嶅簲澶辫触:', res.status);
        setTools([]);
        setLoading(false);
        return;
      }
      
      const data = await res.json();
      const allTools = data.tools || [];
      
      setTools(allTools);
      setCategories(getCategoriesFromTools(allTools));
      setPopularTools(allTools.slice(0, 6));
      setLatestTools(allTools.slice(0, 6));
    } catch (error) {
      console.error('鍔犺浇澶辫触:', error);
      setTools([]);
    } finally {
      setLoading(false);
    }
  }

  function getCategoriesFromTools(tools: any[]) {
    const categories: Record<string, number> = {};
    tools.forEach(tool => {
      categories[tool.category] = (categories[tool.category] || 0) + 1;
    });
    return Object.entries(categories).map(([name, count]) => ({
      id: name,
      name,
      slug: name.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
      count,
    }));
  }

  const getCategoryCount = (name: string) => tools.filter(t => t.category === name).length;

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center gradient-mesh">
        <div className="text-center">
          <div className="relative w-16 h-16 mx-auto mb-4">
            <div className="absolute inset-0 bg-gradient-to-br from-orange-400 to-orange-600 rounded-2xl animate-pulse"></div>
            <div className="absolute inset-0 flex items-center justify-center">
              <span className="text-3xl">馃尠</span>
            </div>
          </div>
          <p className="text-gray-500 text-sm font-medium animate-pulse">姝ｅ湪鍔犺浇宸ュ叿绠?..</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen gradient-mesh">
      {/* ========== 瀵艰埅鏍?- 鐜荤拑鎬?========== */}
      <Header />

      {/* ========== Hero 鍖哄煙 - 鍥介檯澶у笀绾ф帓鐗?========== */}
      <section className="relative py-20 overflow-hidden">
        {/* 鍔ㄦ€佽儗鏅?*/}
        <div className="absolute inset-0 gradient-mesh"></div>
        
        {/* 鍏夋檿鏁堟灉 */}
        <div className="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-gradient-to-br from-orange-300/20 to-amber-300/20 rounded-full blur-3xl animate-pulse-glow"></div>
        <div className="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-gradient-to-br from-amber-300/20 to-yellow-300/20 rounded-full blur-3xl animate-pulse-glow" style={{ animationDelay: '1s' }}></div>
        
        {/* 娴姩瑁呴グ */}
        <div className="absolute top-20 left-10 w-3 h-3 bg-gradient-to-br from-orange-400 to-orange-500 rounded-full opacity-40 animate-float"></div>
        <div className="absolute bottom-32 right-20 w-4 h-4 bg-gradient-to-br from-amber-400 to-amber-500 rounded-full opacity-40 animate-float" style={{ animationDelay: '0.5s' }}></div>
        <div className="absolute top-40 right-32 w-2 h-2 bg-gradient-to-br from-yellow-400 to-yellow-500 rounded-full opacity-40 animate-float" style={{ animationDelay: '1s' }}></div>
        
        <div className="relative container-wide text-center">
          {/* Logo - 甯﹂槾褰卞拰鍔ㄦ晥 */}
          <div className="w-28 h-28 mx-auto mb-8 relative group">
            <div className="absolute inset-0 gradient-primary rounded-3xl shadow-2xl group-hover:shadow-orange-500/40 transition-shadow duration-500"></div>
            <div className="relative w-28 h-28 rounded-3xl flex items-center justify-center">
              <span className="text-white text-6xl group-hover:scale-110 transition-transform duration-500">馃尠</span>
            </div>
          </div>
          
          {/* 涓绘爣棰?- 绮剧‘鎺掔増 */}
          <h1 className="text-5xl md:text-6xl font-bold mb-6 gradient-text tracking-tight">
            绮鹃€?510+ 浼樿川宸ュ叿
          </h1>
          
          {/* 鍓爣棰?*/}
          <p className="text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
            涓€绔欏紡瑙ｅ喅宸ヤ綔鐢熸椿闇€姹傦紝鍙戠幇鎻愬崌鏁堢巼鐨勫埄鍣?          </p>
          
          {/* 鎼滅储妗?- 绮捐嚧璁捐 */}
          <div className="max-w-2xl mx-auto mb-12 group">
            <div className="relative">
              <div className="absolute inset-0 gradient-primary rounded-2xl blur opacity-20 group-hover:opacity-30 transition-opacity"></div>
              <form 
                onSubmit={(e) => {
                  e.preventDefault();
                  const input = e.currentTarget.querySelector('input');

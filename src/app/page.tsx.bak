  { id: 'office', name: '鏁堢巼鍔炲叕', icon: '馃捈', color: 'from-blue-500 to-blue-600', category: '鏁堢巼鍔炲叕', desc: 'Notion銆侀涔︾瓑鍔炲叕鍒╁櫒', slug: 'xiaolv-bangong' },
  { id: 'media', name: '褰辫濞变箰', icon: '馃帴', color: 'from-red-500 to-red-600', category: '褰辫璧勬簮', desc: 'Netflix銆乊ouTube 绛夊奖瑙嗗钩鍙?, slug: 'yingshi-ziyuan' },
  { id: 'music', name: '鍦ㄧ嚎闊充箰', icon: '馃幍', color: 'from-yellow-500 to-yellow-600', category: '鍦ㄧ嚎闊充箰', desc: '缃戞槗浜戙€丵Q 闊充箰绛夐煶涔愬钩鍙?, slug: 'zaixian-yinyue' },
  { id: 'design', name: '璁捐鍒涗綔', icon: '馃帹', color: 'from-pink-500 to-pink-600', category: 'AI 璁捐', desc: 'Midjourney銆丆anva 绛夎璁″伐鍏?, slug: 'ai-sheji' },

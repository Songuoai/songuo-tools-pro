          </div>
        </div>
      </section>

      {/* ========== 鐑棬宸ュ叿 ========== */}
      <section className="py-16">
        <div className="container-wide">
          <div className="flex items-center justify-between mb-10">
            <div>
              <h2 className="text-3xl font-bold mb-2 tracking-tight">鐑棬宸ュ叿</h2>

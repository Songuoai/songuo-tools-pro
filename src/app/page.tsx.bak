                  <div className={`w-14 h-14 mx-auto mb-3 rounded-2xl bg-gradient-to-br ${mainCat.color} flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-110 transition-all duration-300`}>
                    <span className="text-2xl">{mainCat.icon}</span>
